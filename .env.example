# -----------------------------------------------------------------------------
# llm-gateway-stack (Combined LiteLLM + Langfuse stack) configuration
# -----------------------------------------------------------------------------
# Copy this file to .env and replace all generated placeholders, or run:
#   ./scripts/init_env.py
#
# The init script will:
# - create .env from this template
# - generate strong random secrets for placeholder values
# - generate Langfuse bootstrap API keys and LiteLLM callback key placeholders
# - refuse to overwrite .env unless you pass --force

# -----------------------------------------------------------------------------
# Network bindings
# -----------------------------------------------------------------------------
# Services mapped with PUBLIC_BIND_IP are reachable from other machines (if firewall allows).
# Services mapped with LOCAL_BIND_IP are only reachable from this host.
PUBLIC_BIND_IP=0.0.0.0
LOCAL_BIND_IP=127.0.0.1

# -----------------------------------------------------------------------------
# Docker images (pin upgrades explicitly)
# -----------------------------------------------------------------------------
# Defaults match versions validated with `docker manifest inspect` on Sat Mar 28 07:15:31 PM PDT 2026, except:
# - CLICKHOUSE_IMAGE: default is `23.8` (manifest OK).
# - MINIO_IMAGE: default is `RELEASE.2025-09-07T16-13-09Z` (manifest OK).
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-v1.81.14-stable
POSTGRES_IMAGE=docker.io/library/postgres:17.9
NGINX_IMAGE=docker.io/library/nginx:1.27.5-alpine
LANGFUSE_WEB_IMAGE=docker.io/langfuse/langfuse:3.153.0
LANGFUSE_WORKER_IMAGE=docker.io/langfuse/langfuse-worker:3.153.0
REDIS_IMAGE=docker.io/library/redis:7.4.7
CLICKHOUSE_IMAGE=docker.io/clickhouse/clickhouse-server:23.8
PROMETHEUS_IMAGE=docker.io/prom/prometheus:v3.9.1
MINIO_IMAGE=docker.io/minio/minio:RELEASE.2025-09-07T16-13-09Z

# Host path for Postgres data (intentional bind mount; create with correct ownership for the container UID).
POSTGRES_DATA_HOST_PATH=/var/lib/postgresql/litellm/data

# -----------------------------------------------------------------------------
# Host ports (left side of host:container mappings)
# -----------------------------------------------------------------------------
LITELLM_PORT=4123
LANGFUSE_WORKER_PORT=3030
LANGFUSE_WEB_PORT=3000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
MINIO_API_PORT=9092
MINIO_CONSOLE_PORT=9091
REDIS_PORT=6379
POSTGRES_PORT=5432
PROMETHEUS_PORT=9090
NGINX_PORT=80

# -----------------------------------------------------------------------------
# Internal container/service ports (usually leave as defaults)
# -----------------------------------------------------------------------------
POSTGRES_INTERNAL_PORT=5432
LANGFUSE_WEB_INTERNAL_PORT=3000

# -----------------------------------------------------------------------------
# LiteLLM app secrets
# -----------------------------------------------------------------------------
# 24 bytes in hex -> 48 chars
LITELLM_SALT_KEY=__LITELLM_SALT_KEY__
# 32 bytes in hex -> 64 chars
LITELLM_MASTER_KEY=__LITELLM_MASTER_KEY__

# -----------------------------------------------------------------------------
# Shared Postgres root connection
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=postgres

# -----------------------------------------------------------------------------
# LiteLLM Postgres database
# -----------------------------------------------------------------------------
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=llmproxy
LITELLM_DB_PASSWORD=__LITELLM_DB_PASSWORD__
LITELLM_DATABASE_URL=postgresql://llmproxy:${LITELLM_DB_PASSWORD}@postgres:${POSTGRES_INTERNAL_PORT}/litellm

# -----------------------------------------------------------------------------
# Langfuse Postgres database
# -----------------------------------------------------------------------------
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=__LANGFUSE_DB_PASSWORD__
LANGFUSE_DATABASE_URL=postgresql://langfuse:${LANGFUSE_DB_PASSWORD}@postgres:${POSTGRES_INTERNAL_PORT}/langfuse

# -----------------------------------------------------------------------------
# Langfuse auth and crypto
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:${LANGFUSE_WEB_PORT}
# 32 bytes in hex -> 64 chars
NEXTAUTH_SECRET=__NEXTAUTH_SECRET__
LANGFUSE_SALT=__LANGFUSE_SALT__
# Must be exactly 64 hex chars (32 bytes)
LANGFUSE_ENCRYPTION_KEY=__LANGFUSE_ENCRYPTION_KEY__
AUTH_DISABLE_SIGNUP=true
# Langfuse product telemetry (maps to TELEMETRY_ENABLED in containers). Set to false to disable.
# LANGFUSE_TELEMETRY_ENABLED=true
# Experimental UI/API features; consider false for conservative production.
# LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true
# Optional bootstrap keys for first Langfuse project creation.
#
# These are auto-generated by scripts/init_env.py and also used by LiteLLM.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-__LANGFUSE_INIT_PROJECT_PUBLIC_KEY__
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-__LANGFUSE_INIT_PROJECT_SECRET_KEY__
LANGFUSE_INIT_ORG_ID=00000000-0000-0000-0000-000000000001
LANGFUSE_INIT_ORG_NAME=Default Org
LANGFUSE_INIT_PROJECT_ID=00000000-0000-0000-0000-000000000002
LANGFUSE_INIT_PROJECT_NAME=Default Project
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=__LANGFUSE_INIT_USER_PASSWORD__
# LiteLLM→Langfuse callbacks (same placeholders as LANGFUSE_INIT_PROJECT_*; init_env fills both).
LANGFUSE_PUBLIC_KEY=pk-lf-__LANGFUSE_INIT_PROJECT_PUBLIC_KEY__
LANGFUSE_SECRET_KEY=sk-lf-__LANGFUSE_INIT_PROJECT_SECRET_KEY__
LANGFUSE_HOST=http://langfuse-web:${LANGFUSE_WEB_INTERNAL_PORT}

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=__CLICKHOUSE_PASSWORD__

# -----------------------------------------------------------------------------
# MinIO + Redis
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=__MINIO_ROOT_PASSWORD__
MINIO_BROWSER_REDIRECT_URL=http://localhost:${NGINX_PORT}/minio/
REDIS_AUTH=__REDIS_AUTH__

# -----------------------------------------------------------------------------
# Langfuse object storage (S3-compatible) credentials and endpoints
# -----------------------------------------------------------------------------
# By default this reuses the same MinIO credentials for all Langfuse S3 channels.
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=${MINIO_ROOT_USER}
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=${MINIO_ROOT_USER}
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=${MINIO_ROOT_USER}
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

# External endpoints should match your host/ingress configuration.
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://localhost:${MINIO_API_PORT}
LANGFUSE_S3_BATCH_EXPORT_EXTERNAL_ENDPOINT=http://localhost:${MINIO_API_PORT}
